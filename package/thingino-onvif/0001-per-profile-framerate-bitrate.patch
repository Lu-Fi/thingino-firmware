                         <tt:Quality>10</tt:Quality>
                         <tt:RateControl>
-                            <tt:FrameRateLimit>30</tt:FrameRateLimit>
-                            <tt:BitrateLimit>5000</tt:BitrateLimit>
+                            <tt:FrameRateLimit>%FRAMERATE%</tt:FrameRateLimit>
